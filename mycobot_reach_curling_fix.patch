From 211fd3c0af134c27feddd4c04e654af6ad7ca12b Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Thu, 18 Jun 2026 07:13:36 +0000
Subject: [PATCH] Fix MyCobot280 reach curling: add ready pose + raise action
 authority

The arm trained but parked/curled instead of tracking the command, while the
same reach task works for Franka. Root cause found by comparing the two configs:

- Franka's default joint_pos is a bent "ready" pose (hand already over the
  table), so with use_default_offset=True and scale=0.5 the policy only needs
  small joint deltas to span its workspace.
- MyCobot280's default was all zeros = arm straight up at a singularity. With
  use_default_offset=True the policy can only perturb around straight-up and can
  never bend down/forward to the targets, so it collapses to the closest pose it
  can reach (the "curl"). Reward still rises because it gets marginally closer.

Fixes:
- Give MyCobot280 a real forward/down ready pose in its ArticulationCfg, mirroring
  Franka. The reset offset and action offset now start inside the workspace.
- Raise the joint-position action scale 0.5 -> 1.5 so the small arm has enough
  authority to span its workspace even from an imperfect home pose.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_011nhXLvD3KD12ZUgM8kqdPB
---
 joint_pos_env_cfg.py                          | 24 +++++++++++++------
 mycobot280.py                                 | 18 ++++++++++----
 .../isaaclab_assets/robots/mycobot280.py      | 18 ++++++++++----
 .../config/mycobot280/joint_pos_env_cfg.py    | 24 +++++++++++++------
 4 files changed, 62 insertions(+), 22 deletions(-)

diff --git a/joint_pos_env_cfg.py b/joint_pos_env_cfg.py
index f67b3c6..3829860 100644
--- a/joint_pos_env_cfg.py
+++ b/joint_pos_env_cfg.py
@@ -17,9 +17,18 @@ class MyCobotReachEnvCfg(ReachEnvCfg):
             asset_name="robot",
             joint_names=["joint2_to_joint1", "joint3_to_joint2", "joint4_to_joint3",
                          "joint5_to_joint4", "joint6_to_joint5", "joint6output_to_joint6"],
-            # 0.2 was copied from a larger arm and barely lets the policy move; 0.5
-            # gives enough range/exploration for a small arm to span its workspace.
-            scale=0.5,
+            # ROOT CAUSE of the curling: with use_default_offset=True the policy commands
+            # joint_target = action * scale + default_joint_pos. Franka works at scale=0.5
+            # because its default_joint_pos is a *ready* pose (elbow bent, hand already over
+            # the table), so tiny actions cover the workspace. The MyCobot280 default is ALL
+            # ZEROS (arm straight up), so a small scale can only wiggle near the straight-up
+            # singularity and can NEVER bend down/forward to the targets -> the policy parks
+            # in the closest it can manage, which looks like curling. We do two things:
+            #   1) give the arm a real ready pose in mycobot280.py (so the offset starts in
+            #      the workspace, exactly like Franka), and
+            #   2) raise the action scale so the policy has enough authority to span the
+            #      small arm's workspace even from an imperfect home pose.
+            scale=1.5,
             use_default_offset=True,
         )
 
@@ -34,10 +43,11 @@ class MyCobotReachEnvCfg(ReachEnvCfg):
         self.commands.ee_pose.ranges.pos_z = (0.10, 0.28)
         self.commands.ee_pose.ranges.pitch = (math.pi, math.pi)
 
-        # The base ReachEnvCfg resets joints with reset_joints_by_scale, which MULTIPLIES
-        # the default joint positions. Our defaults are all 0.0, so that reset produced
-        # ZERO start-pose randomization (0 * scale = 0) and every episode began identically.
-        # Switch to an additive offset so the arm actually starts from varied poses.
+        # Randomize the start pose with an ADDITIVE offset around the ready pose. The base
+        # ReachEnvCfg uses reset_joints_by_scale, which MULTIPLIES the default joint
+        # positions - that is fragile for us (it gave zero randomization back when the
+        # defaults were all 0.0). An additive offset gives consistent +/-0.6 rad spread
+        # around whatever ready pose we set, so every episode starts from a varied pose.
         self.events.reset_robot_joints.func = mdp.reset_joints_by_offset
         self.events.reset_robot_joints.params = {
             "position_range": (-0.6, 0.6),
diff --git a/mycobot280.py b/mycobot280.py
index a56a1f8..cdae153 100644
--- a/mycobot280.py
+++ b/mycobot280.py
@@ -15,12 +15,22 @@ MYCOBOT280_CFG = ArticulationCfg(
         ),
     ),
     init_state=ArticulationCfg.InitialStateCfg(
+        # A NON-ZERO "ready" pose is essential, exactly like Franka's default (which is a
+        # bent elbow pose with the hand over the table). All-zeros = arm straight up at a
+        # singularity; with use_default_offset=True the reach policy perturbs around this
+        # pose, so starting straight up makes the forward/low targets effectively
+        # unreachable and the policy collapses into a curl. These values bend the arm
+        # forward and point the flange down so the offset starts inside the workspace.
+        #
+        # NOTE: verify this visually once (the arm should rest reaching forward/down over
+        # the table, not folded back or pointing up). If it rests in the wrong direction,
+        # flip the sign of joint3_to_joint2 (shoulder) and/or joint5_to_joint4 (wrist).
         joint_pos={
-            "joint2_to_joint1": 0.0,
-            "joint3_to_joint2": 0.0,
-            "joint4_to_joint3": 0.0,
+            "joint2_to_joint1": 0.0,    # base yaw - face forward (+x)
+            "joint3_to_joint2": -1.2,   # shoulder - bend the arm forward/down
+            "joint4_to_joint3": -0.6,   # elbow
             "joint5_to_joint4": 0.0,
-            "joint6_to_joint5": 0.0,
+            "joint6_to_joint5": -1.0,   # wrist pitch - point the flange toward the targets
             "joint6output_to_joint6": 0.0,
             "gripper_controller": 0.0,
         },
